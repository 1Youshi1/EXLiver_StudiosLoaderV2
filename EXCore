    -- ============== ФУНКЦИИ ==============
    function createESP()
        if espConn then espConn:Disconnect() end
        for _,d in pairs(drawings) do if d then d:Remove() end end
        drawings = {}
        local any=false
        for _,v in pairs(espSettings) do if v.Enabled then any=true break end end
        if not any then return end
        espConn = RunService.RenderStepped:Connect(function()
            for _,plr in ipairs(Players:GetPlayers()) do
                if plr==player or not plr.Character or not plr.Character:FindFirstChild("Head") then continue end
                local head=plr.Character.Head
                local pos, onScreen = camera:WorldToViewportPoint(head.Position)
                local id=plr.UserId
                if onScreen then
                    if espSettings.Box.Enabled then
                        local d=drawings[id.."_box"] or Drawing.new("Square")
                        d.Visible=true; d.Color=espSettings.Box.Color; d.Thickness=espSettings.Box.Thickness; d.Filled=false
                        d.Size=Vector2.new(50,80); d.Position=Vector2.new(pos.X-25,pos.Y-40)
                        drawings[id.."_box"]=d
                    end
                    if espSettings.Name.Enabled then
                        local d=drawings[id.."_name"] or Drawing.new("Text")
                        d.Visible=true; d.Text=plr.Name; d.Color=espSettings.Name.Color; d.Size=13
                        d.Position=Vector2.new(pos.X,pos.Y-60); d.Center=true
                        drawings[id.."_name"]=d
                    end
                    if espSettings.Distance.Enabled then
                        local d=drawings[id.."_dist"] or Drawing.new("Text")
                        d.Visible=true; local root=player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                        local dist=root and (root.Position-head.Position).Magnitude or 0
                        d.Text=math.floor(dist).."m"; d.Color=espSettings.Distance.Color; d.Size=13
                        d.Position=Vector2.new(pos.X,pos.Y-45); d.Center=true
                        drawings[id.."_dist"]=d
                    end
                    if espSettings.Tracer.Enabled then
                        local d=drawings[id.."_tracer"] or Drawing.new("Line")
                        d.Visible=true; d.From=Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y)
                        d.To=Vector2.new(pos.X,pos.Y); d.Color=espSettings.Tracer.Color; d.Thickness=espSettings.Tracer.Thickness
                        drawings[id.."_tracer"]=d
                    end
                    if espSettings.HealthBar.Enabled then
                        local d=drawings[id.."_health"] or Drawing.new("Square")
                        d.Visible=true; local hum=plr.Character:FindFirstChild("Humanoid")
                        local h=hum and hum.Health/hum.MaxHealth or 1
                        d.Color=Color3.new(1-h,h,0); d.Filled=true
                        d.Size=Vector2.new(2,40*h); d.Position=Vector2.new(pos.X-30,pos.Y-20)
                        drawings[id.."_health"]=d
                    end
                    if espSettings.HeadDot.Enabled then
                        local d=drawings[id.."_dot"] or Drawing.new("Square")
                        d.Visible=true; d.Color=espSettings.HeadDot.Color; d.Filled=true
                        d.Size=Vector2.new(6,6); d.Position=Vector2.new(pos.X-3,pos.Y-3)
                        drawings[id.."_dot"]=d
                    end
                else
                    for _,tag in ipairs({"_box","_name","_dist","_tracer","_health","_dot"}) do
                        local d=drawings[id..tag] if d then d.Visible=false end
                    end
                end
            end
        end)
    end

    function updateChams()
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr~=player and plr.Character then
                local hl = plr.Character:FindFirstChild("EXCore_Chams") or Instance.new("Highlight")
                hl.Name="EXCore_Chams"
                hl.FillColor=chamsColor
                hl.OutlineColor=Color3.new(1,1,1)
                hl.FillTransparency=chamsEnabled and chamsFillTransparency or 1
                hl.OutlineTransparency=chamsEnabled and 0 or 1
                hl.Enabled=chamsEnabled
                if not hl.Parent then hl.Adornee=plr.Character hl.Parent=plr.Character end
            end
        end
    end

    aimbotConn = RunService.Heartbeat:Connect(function()
        if not aimbotEnabled or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
        local target,shortestDist=nil,aimFOV
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr~=player and plr.Character and plr.Character:FindFirstChild("Head") and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health>0 then
                local pos,onScreen=camera:WorldToViewportPoint(plr.Character.Head.Position)
                local dist=(Vector2.new(pos.X,pos.Y)-camera.ViewportSize/2).Magnitude
                if onScreen and dist<shortestDist then shortestDist=dist target=plr.Character.Head end
            end
        end
        if target then
            if aimPrediction then
                -- простое предсказание по Velocity
                local vel = target.Velocity
                camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, target.Position + vel*0.15), aimSmooth)
            else
                camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, target.Position), aimSmooth)
            end
        end
    end)

    -- Легитный аим
    legitConn = RunService.Heartbeat:Connect(function()
        if not legitAimEnabled or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
        local target,shortestDist=nil,legitFOV
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr~=player and plr.Character and plr.Character:FindFirstChild("Head") and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health>0 then
                local pos,onScreen=camera:WorldToViewportPoint(plr.Character.Head.Position)
                local dist=(Vector2.new(pos.X,pos.Y)-camera.ViewportSize/2).Magnitude
                if onScreen and dist<shortestDist then shortestDist=dist target=plr.Character.Head end
            end
        end
        if target then
            local goal = camera:WorldToScreenPoint(target.Position)
            local mousePos = UIS:GetMouseLocation()
            local delta = Vector2.new(goal.X - mousePos.X, goal.Y - mousePos.Y)
            mousemoverel(delta.X * legitSmooth, delta.Y * legitSmooth)
        end
    end)

    -- Триггербот
    triggerConn = RunService.Heartbeat:Connect(function()
        if not triggerEnabled or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
        local mouse = UIS:GetMouseLocation()
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr~=player and plr.Character and plr.Character:FindFirstChild("Head") and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health>0 then
                local pos = camera:WorldToScreenPoint(plr.Character.Head.Position)
                if (Vector2.new(pos.X,pos.Y)-mouse).Magnitude < 20 then
                    task.wait(triggerDelay)
                    if triggerEnabled then
                        -- симуляция клика
                        mouse1press()
                        task.wait(0.05)
                        mouse1release()
                    end
                    break
                end
            end
        end
    end)

    function toggleFly(v)
        flyEnabled = v
        local char = player.Character or player.CharacterAdded:Wait()
        local root = char:WaitForChild("HumanoidRootPart")
        local hum = char:WaitForChild("Humanoid")
        if v then
            hum.PlatformStand = true
            flyBodyGyro = Instance.new("BodyGyro", root)
            flyBodyGyro.MaxTorque = Vector3.new(400000,400000,400000)
            flyBodyGyro.CFrame = root.CFrame
            flyBodyVel = Instance.new("BodyVelocity", root)
            flyBodyVel.MaxForce = Vector3.new(400000,400000,400000)
            flyBodyVel.Velocity = Vector3.new()
            flyConn = RunService.Heartbeat:Connect(function()
                if not flyEnabled or not player.Character then return end
                local r = player.Character.HumanoidRootPart
                local dir = Vector3.new()
                if UIS:IsKeyDown(Enum.KeyCode.W) then dir += camera.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.S) then dir -= camera.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.A) then dir -= camera.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.D) then dir += camera.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.new(0,1,0) end
                if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then dir -= Vector3.new(0,1,0) end
                if dir.Magnitude > 0 then
                    flyBodyVel.Velocity = dir.Unit * 50
                    flyBodyGyro.CFrame = CFrame.new(r.Position, r.Position + camera.CFrame.LookVector)
                else
                    flyBodyVel.Velocity = Vector3.new(0,0,0)
                    flyBodyGyro.CFrame = root.CFrame
                end
            end)
        else
            if flyConn then flyConn:Disconnect() end
            if flyBodyVel then flyBodyVel:Destroy() end
            if flyBodyGyro then flyBodyGyro:Destroy() end
            hum.PlatformStand = false
        end
    end

    function toggleNoclip(v)
        noclipEnabled = v
        if v then
            noclipConn = RunService.Stepped:Connect(function()
                if player.Character then
                    for _,p in ipairs(player.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
                end
            end)
        else
            if noclipConn then noclipConn:Disconnect() end
            if player.Character then
                for _,p in ipairs(player.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=true end end
            end
        end
    end

