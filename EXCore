    local function selectTab(name)
        if currentTab == name then return end
        local oldTab, newTab
        for _, t in ipairs(tabs) do
            if t.Name == name then newTab = t end
            if t.Name == currentTab then oldTab = t end
        end
        if oldTab then
            -- Анимация исчезновения старого контента
            TweenService:Create(oldTab.Content, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
