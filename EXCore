    function createESP()
        if espConn then espConn:Disconnect() end
        for _,d in pairs(drawings) do if d then d:Remove() end end
        drawings = {}
        local anyEnabled = false
        for _,v in pairs(espSettings) do if v.Enabled then anyEnabled = true break end end
        if not anyEnabled then return end

        espConn = RunService.RenderStepped:Connect(function()
            for _,plr in ipairs(Players:GetPlayers()) do
                if plr == player or not plr.Character or not plr.Character:FindFirstChild("Head") then continue end
                local head = plr.Character.Head
                local pos, onScreen = camera:WorldToViewportPoint(head.Position)
                local id = plr.UserId
                if onScreen then
                    if espSettings.Box.Enabled then
                        local box = drawings[id.."_box"] or Drawing.new("Square")
                        box.Visible = true
                        box.Color = espSettings.Box.Color
                        box.Thickness = espSettings.Box.Thickness
                        box.Filled = false
                        box.Size = Vector2.new(50, 80)
                        box.Position = Vector2.new(pos.X-25, pos.Y-40)
                        drawings[id.."_box"] = box
                    end
                    if espSettings.Name.Enabled then
                        local name = drawings[id.."_name"] or Drawing.new("Text")
                        name.Visible = true
                        name.Text = plr.Name
                        name.Color = espSettings.Name.Color
                        name.Size = 13
                        name.Position = Vector2.new(pos.X, pos.Y-60)
                        name.Center = true
                        drawings[id.."_name"] = name
                    end
                    if espSettings.Distance.Enabled then
                        local dist = drawings[id.."_dist"] or Drawing.new("Text")
                        dist.Visible = true
                        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                        local d = root and (root.Position-head.Position).Magnitude or 0
                        dist.Text = math.floor(d).."m"
                        dist.Color = espSettings.Distance.Color
                        dist.Size = 13
                        dist.Position = Vector2.new(pos.X, pos.Y-45)
                        dist.Center = true
                        drawings[id.."_dist"] = dist
                    end
                    if espSettings.Tracer.Enabled then
                        local tracer = drawings[id.."_tracer"] or Drawing.new("Line")
                        tracer.Visible = true
                        tracer.From = Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y)
                        tracer.To = Vector2.new(pos.X, pos.Y)
                        tracer.Color = espSettings.Tracer.Color
                        tracer.Thickness = espSettings.Tracer.Thickness
                        drawings[id.."_tracer"] = tracer
                    end
                    if espSettings.HealthBar.Enabled then
                        local health = drawings[id.."_health"] or Drawing.new("Square")
                        health.Visible = true
                        local hum = plr.Character:FindFirstChild("Humanoid")
                        local h = hum and hum.Health/hum.MaxHealth or 1
                        health.Color = Color3.new(1-h, h, 0)
                        health.Filled = true
                        health.Size = Vector2.new(2, 40*h)
                        health.Position = Vector2.new(pos.X-30, pos.Y-20)
                        drawings[id.."_health"] = health
                    end
                    if espSettings.HeadDot.Enabled then
                        local dot = drawings[id.."_dot"] or Drawing.new("Square")
                        dot.Visible = true
                        dot.Color = espSettings.HeadDot.Color
                        dot.Filled = true
                        dot.Size = Vector2.new(6,6)
                        dot.Position = Vector2.new(pos.X-3, pos.Y-3)
                        drawings[id.."_dot"] = dot
                    end
                else
                    for _,tag in ipairs({"_box","_name","_dist","_tracer","_health","_dot"}) do
                        local d = drawings[id..tag]
                        if d then d.Visible = false end
                    end
                end
            end
        end)
    end

