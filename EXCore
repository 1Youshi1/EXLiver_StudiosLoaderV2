    -- ============== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ UI ==============
    local function sec(parent, name, y, h)
        local s = Instance.new("Frame", parent):Apply({
            Size=UDim2.new(1,-20,0,h or 200), Position=UDim2.new(0,10,0,y),
            BackgroundColor3=Color3.fromRGB(20,20,25), BorderSizePixel=0
        })
        Instance.new("UICorner", s).CornerRadius = UDim.new(0,6)
        Instance.new("TextLabel", s):Apply({
            Size=UDim2.new(1,-10,0,20), Position=UDim2.new(0,5,0,5),
            BackgroundTransparency=1, Font=Enum.Font.GothamBold, Text=name,
            TextColor3=Color3.fromRGB(255,255,255), TextSize=13, TextXAlignment=Enum.TextXAlignment.Left
        })
        return s
    end
    local function toggle(parent, y, name, def, cb)
        local b = Instance.new("TextButton", parent):Apply({
            Size=UDim2.new(1,-20,0,26), Position=UDim2.new(0,10,0,30 + y*28),
            BackgroundColor3=def and Color3.fromRGB(50,200,100) or Color3.fromRGB(80,80,80),
            BorderSizePixel=0, Text="  "..name, Font=Enum.Font.Gotham, TextColor3=Color3.fromRGB(255,255,255),
            TextSize=13, TextXAlignment=Enum.TextXAlignment.Left, AutoButtonColor=false
        })
        Instance.new("UICorner", b).CornerRadius = UDim.new(0,3)
        local s=def
        b.MouseButton1Click:Connect(function() s=not s b.BackgroundColor3 = s and Color3.fromRGB(50,200,100) or Color3.fromRGB(80,80,80) if cb then cb(s) end end)
        return b
    end
    local function slider(parent, y, name, min, max, def, cb)
        local f = Instance.new("Frame", parent):Apply({Size=UDim2.new(1,-20,0,38), Position=UDim2.new(0,10,0,30 + y*40), BackgroundTransparency=1})
        local lbl = Instance.new("TextLabel", f):Apply({Size=UDim2.new(1,0,0,15), BackgroundTransparency=1, Font=Enum.Font.Gotham, Text=name..": "..def, TextColor3=Color3.fromRGB(200,200,200), TextSize=12, TextXAlignment=Enum.TextXAlignment.Left})
        local s = Instance.new("TextButton", f):Apply({Size=UDim2.new(1,0,0,8), Position=UDim2.new(0,0,0,20), BackgroundColor3=Color3.fromRGB(45,45,50), BorderSizePixel=0, Text="", AutoButtonColor=false})
        Instance.new("UICorner", s).CornerRadius = UDim.new(0,4)
        local fill = Instance.new("Frame", s):Apply({Size=UDim2.new((def-min)/(max-min),0,1,0), BackgroundColor3=Color3.fromRGB(70,150,255), BorderSizePixel=0})
        Instance.new("UICorner", fill).CornerRadius = UDim.new(0,4)
        local drag=false, cur=def
        local function upd(v) fill.Size=UDim2.new((v-min)/(max-min),0,1,0) lbl.Text=name..": "..math.round(v*10)/10 if cb then cb(v) end end
        s.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end end)
        s.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
        UIS.InputChanged:Connect(function(i) if drag and i.UserInputType==Enum.UserInputType.MouseMovement then local rel=math.clamp((i.Position.X-s.AbsolutePosition.X)/s.AbsoluteSize.X,0,1) cur=min+rel*(max-min) upd(cur) end end)
        return f
    end
    local function colorpicker(parent, y, name, def, cb)
        local f = Instance.new("Frame", parent):Apply({Size=UDim2.new(1,-20,0,32), Position=UDim2.new(0,10,0,30 + y*34), BackgroundTransparency=1})
        Instance.new("TextLabel", f):Apply({Size=UDim2.new(0,80,0,20), BackgroundTransparency=1, Font=Enum.Font.Gotham, Text=name, TextColor3=Color3.fromRGB(200,200,200), TextSize=12, TextXAlignment=Enum.TextXAlignment.Left})
        local preview = Instance.new("Frame", f):Apply({Size=UDim2.new(0,24,0,24), Position=UDim2.new(0,90,0,0), BackgroundColor3=def, BorderSizePixel=0})
        Instance.new("UICorner", preview).CornerRadius = UDim.new(0,4)
        local r,g,b = def.R*255, def.G*255, def.B*255
        local function uc() local c=Color3.fromRGB(r,g,b) preview.BackgroundColor3=c if cb then cb(c) end end
        for i,ch in ipairs({"R","G","B"}) do
            local bb = Instance.new("TextButton", f):Apply({Size=UDim2.new(0,20,0,20), Position=UDim2.new(0,120+(i-1)*25,0,2), BackgroundColor3=Color3.fromRGB(50,50,50), Text=ch, Font=Enum.Font.GothamBold, TextColor3=Color3.fromRGB(255,255,255), TextSize=12, AutoButtonColor=false})
            Instance.new("UICorner", bb).CornerRadius = UDim.new(0,3)
            bb.MouseButton1Click:Connect(function()
                local v = ch=="R" and r or ch=="G" and g or b
                v = (v+30)%255
                if ch=="R" then r=v elseif ch=="G" then g=v else b=v end
                uc()
            end)
        end
    end
    local function keybind(parent, y, name, defkey, cb)
        local f = Instance.new("Frame", parent):Apply({Size=UDim2.new(1,-20,0,28), Position=UDim2.new(0,10,0,30 + y*34), BackgroundTransparency=1})
        Instance.new("TextLabel", f):Apply({Size=UDim2.new(0,80,0,20), BackgroundTransparency=1, Font=Enum.Font.Gotham, Text=name, TextColor3=Color3.fromRGB(200,200,200), TextSize=12, TextXAlignment=Enum.TextXAlignment.Left})
        local btn = Instance.new("TextButton", f):Apply({Size=UDim2.new(0,80,0,22), Position=UDim2.new(0,100,0,0), BackgroundColor3=Color3.fromRGB(50,50,55), BorderSizePixel=0, Text=defkey or "None", Font=Enum.Font.Gotham, TextColor3=Color3.fromRGB(255,255,255), TextSize=13, AutoButtonColor=false})
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0,3)
        local binding=false
        btn.MouseButton1Click:Connect(function() binding=true btn.Text="..." end)
        UIS.InputBegan:Connect(function(i,g) if binding and not g and i.UserInputType==Enum.UserInputType.Keyboard then binding=false btn.Text=i.KeyCode.Name cb(i.KeyCode) end end)
        return f
    end

