            task.delay(0.2, function()
                oldTab.Content.Visible = false
                oldTab.Button.BackgroundColor3 = Color3.fromRGB(30,30,35)
            end)
        end
        if newTab then
            newTab.Content.Position = UDim2.new(0, 30, 0, 0)
            newTab.Content.BackgroundTransparency = 1
            newTab.Content.Visible = true
            TweenService:Create(newTab.Content, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Position = UDim2.new(0, 0, 0, 0),
