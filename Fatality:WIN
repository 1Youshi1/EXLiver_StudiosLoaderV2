-- === ДОБАВЛЕНИЕ 45+ ТОГГЛОВ ===
local function AddToggle(tab, name, default, callback)
    local y = #tab:GetChildren() * 55
    local btn = Instance.new("TextButton", tab)
    btn.Size = UDim2.new(0, 680, 0, 50)
    btn.Position = UDim2.new(0, 20, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
    btn.Text = "  " .. name
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 16
    btn.TextXAlignment = Enum.TextXAlignment.Left

    local status = Instance.new("Frame", btn)
    status.Size = UDim2.new(0, 44, 0, 28)
    status.Position = UDim2.new(1, -60, 0.5, -14)
    status.BackgroundColor3 = default and Color3.fromRGB(138,43,226) or Color3.fromRGB(50,50,60)

    local corner = Instance.new("UICorner", status); corner.CornerRadius = UDim.new(0,14)
    local indicator = Instance.new("Frame", status)
    indicator.Size = UDim2.new(0, 24, 0, 24)
    indicator.Position = default and UDim2.new(1,-26,0.5,-12) or UDim2.new(0,2,0.5,-12)
    indicator.BackgroundColor3 = Color3.new(1,1,1)
    local indCorner = Instance.new("UICorner", indicator); indCorner.CornerRadius = UDim.new(1,0)

    btn.MouseButton1Click:Connect(function()
        default = not default
        TweenService:Create(status, TweenInfo.new(0.25), {BackgroundColor3 = default and Color3.fromRGB(138,43,226) or Color3.fromRGB(50,50,60)}):Play()
        TweenService:Create(indicator, TweenInfo.new(0.25), {Position = default and UDim2.new(1,-26,0.5,-12) or UDim2.new(0,2,0.5,-12)}):Play()
        callback(default)
    end)
end

